<% if (flash) { %>
  <div
    class="mx-auto mb-6 max-w-7xl rounded-3xl border px-5 py-4 text-sm shadow-panel <%= flash.type === 'success' ? 'border-emerald-400/30 bg-emerald-400/10 text-emerald-100' : 'border-rose-400/30 bg-rose-400/10 text-rose-100' %>"
  >
    <%= flash.message %>
  </div>
<% } %>
