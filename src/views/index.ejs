<%- include("partials/head", { title }) %>
<%- include("partials/navbar") %>

<main class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-[-8rem] h-72 w-72 -translate-x-1/2 rounded-full bg-cyan-400/20 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-80 w-80 rounded-full bg-teal-400/10 blur-3xl"></div>
  </div>

  <section class="mx-auto grid min-h-[calc(100vh-9rem)] max-w-7xl gap-14 px-6 pb-16 pt-10 lg:grid-cols-[1.15fr_0.85fr] lg:px-8 lg:pt-16">
    <div class="relative z-10 flex flex-col justify-center">
      <span class="mb-6 inline-flex w-fit rounded-full border border-cyan-300/20 bg-cyan-300/10 px-4 py-2 text-sm font-medium text-cyan-100">
        Secure. Minimal. Internship-ready.
      </span>
      <h1 class="max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-white md:text-6xl">
        File-based authentication with a clean admin workflow.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
        A polished full stack starter where users can register and sign in, while the predefined admin can monitor, update, and delete user accounts from a protected dashboard.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/signup"
          class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-100"
        >
          Create account
        </a>
        <a
          href="/login"
          class="inline-flex items-center justify-center rounded-full border border-white/10 px-6 py-3 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/40 hover:text-white"
        >
          Admin login
        </a>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-3">
        <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-panel backdrop-blur">
          <p class="text-sm text-slate-400">Backend</p>
          <p class="mt-2 text-xl font-semibold text-white">Node.js + Express</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-panel backdrop-blur">
          <p class="text-sm text-slate-400">Storage</p>
          <p class="mt-2 text-xl font-semibold text-white">JSON file system</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-panel backdrop-blur">
          <p class="text-sm text-slate-400">Styling</p>
          <p class="mt-2 text-xl font-semibold text-white">Tailwind CSS</p>
        </div>
      </div>
    </div>

    <div class="relative z-10 flex items-center">
      <div class="w-full rounded-[2rem] border border-white/10 bg-white/10 p-6 shadow-panel backdrop-blur-xl">
        <div class="grid gap-5">
          <div class="rounded-3xl border border-white/10 bg-slate-950/70 p-5">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-slate-400">Administrator</p>
                <h2 class="mt-1 text-lg font-semibold text-white">Predefined secure access</h2>
              </div>
              <span class="rounded-full bg-cyan-300/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100">
                Admin only
              </span>
            </div>
            <div class="mt-5 space-y-3 text-sm text-slate-300">
              <p><span class="text-slate-500">Email:</span> admin@example.com</p>
              <p><span class="text-slate-500">Username:</span> admin</p>
              <p><span class="text-slate-500">Password:</span> password</p>
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-5">
              <p class="text-sm text-slate-400">Access control</p>
              <p class="mt-2 text-base font-semibold text-white">Only the seeded admin can manage users.</p>
            </div>
            <div class="rounded-3xl border border-white/10 bg-white/5 p-5">
              <p class="text-sm text-slate-400">Deployment friendly</p>
              <p class="mt-2 text-base font-semibold text-white">No database required for production setup.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
