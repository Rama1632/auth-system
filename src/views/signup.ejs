<%- include("partials/head", { title }) %>
<%- include("partials/navbar") %>

<main class="relative overflow-hidden px-6 py-10 lg:px-8 lg:py-16">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute right-0 top-16 h-96 w-96 rounded-full bg-teal-400/10 blur-3xl"></div>
  </div>

  <%- include("partials/flash") %>

  <section class="relative mx-auto max-w-2xl">
    <div class="rounded-[2rem] border border-white/10 bg-white/10 p-8 shadow-panel backdrop-blur-xl">
      <div class="mb-8">
        <p class="text-sm font-medium uppercase tracking-[0.22em] text-cyan-200">Create account</p>
        <h1 class="mt-3 text-3xl font-bold text-white">Register as a new user</h1>
        <p class="mt-3 text-slate-300">
          This registration creates a standard user account. Only the predefined admin has access to user management.
        </p>
      </div>

      <% if (errors.length) { %>
        <div class="mb-6 rounded-2xl border border-rose-400/30 bg-rose-400/10 px-4 py-3 text-sm text-rose-100">
          <ul class="space-y-1">
            <% errors.forEach((error) => { %>
              <li><%= error %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/signup" method="post" class="grid gap-5 md:grid-cols-2">
        <label class="block md:col-span-2">
          <span class="mb-2 block text-sm font-medium text-slate-200">Full Name</span>
          <input
            type="text"
            name="name"
            value="<%= formData.name %>"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="Enter your full name"
            required
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-200">Username</span>
          <input
            type="text"
            name="username"
            value="<%= formData.username %>"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="Choose a username"
            required
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-200">Email</span>
          <input
            type="email"
            name="email"
            value="<%= formData.email %>"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="you@example.com"
            required
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-200">Password</span>
          <input
            type="password"
            name="password"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="Minimum 6 characters"
            required
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-200">Confirm Password</span>
          <input
            type="password"
            name="confirmPassword"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="Repeat your password"
            required
          />
        </label>

        <button
          type="submit"
          class="md:col-span-2 rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-100"
        >
          Create Account
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-slate-400">
        Already registered?
        <a href="/login" class="font-semibold text-cyan-200 hover:text-cyan-100">Sign in here</a>
      </p>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
