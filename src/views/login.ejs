<%- include("partials/head", { title }) %>
<%- include("partials/navbar") %>

<main class="relative overflow-hidden px-6 py-10 lg:px-8 lg:py-16">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-20 h-80 w-80 -translate-x-1/2 rounded-full bg-cyan-500/15 blur-3xl"></div>
  </div>

  <%- include("partials/flash") %>

  <section class="relative mx-auto max-w-lg">
    <div class="rounded-[2rem] border border-white/10 bg-white/10 p-8 shadow-panel backdrop-blur-xl">
      <div class="mb-8">
        <p class="text-sm font-medium uppercase tracking-[0.22em] text-cyan-200">Welcome back</p>
        <h1 class="mt-3 text-3xl font-bold text-white">Sign in to your account</h1>
        <p class="mt-3 text-slate-300">
          Use your email or username to access your dashboard. The admin account is predefined for this assignment.
        </p>
      </div>

      <% if (errors.length) { %>
        <div class="mb-6 rounded-2xl border border-rose-400/30 bg-rose-400/10 px-4 py-3 text-sm text-rose-100">
          <ul class="space-y-1">
            <% errors.forEach((error) => { %>
              <li><%= error %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/login" method="post" class="space-y-5">
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-200">Email or Username</span>
          <input
            type="text"
            name="identity"
            value="<%= formData.identity %>"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="Enter email or username"
            required
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-200">Password</span>
          <input
            type="password"
            name="password"
            class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-300/50"
            placeholder="Enter password"
            required
          />
        </label>

        <button
          type="submit"
          class="w-full rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-100"
        >
          Sign In
        </button>
      </form>

      <div class="mt-8 rounded-2xl border border-white/10 bg-slate-950/50 p-4 text-sm text-slate-300">
        <p class="font-semibold text-white">Admin credentials</p>
        <p class="mt-2">Email: admin@example.com</p>
        <p>Username: admin</p>
        <p>Password: password</p>
      </div>

      <p class="mt-6 text-center text-sm text-slate-400">
        New here?
        <a href="/signup" class="font-semibold text-cyan-200 hover:text-cyan-100">Create an account</a>
      </p>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
