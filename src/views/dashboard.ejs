<%- include("partials/head", { title }) %>
<%- include("partials/navbar") %>

<main class="relative overflow-hidden px-6 py-10 lg:px-8 lg:py-14">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-0 top-16 h-80 w-80 rounded-full bg-cyan-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 right-12 h-96 w-96 rounded-full bg-teal-400/10 blur-3xl"></div>
  </div>

  <%- include("partials/flash") %>

  <section class="relative mx-auto max-w-7xl space-y-8">
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-[2rem] border border-white/10 bg-white/10 p-8 shadow-panel backdrop-blur-xl">
        <p class="text-sm font-medium uppercase tracking-[0.22em] text-cyan-200">
          <%= currentUser.role === "admin" ? "Administrator area" : "Member area" %>
        </p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-white">
          Hello, <%= currentUser.name %>
        </h1>
        <p class="mt-4 max-w-2xl text-slate-300">
          You are signed in as <span class="font-semibold text-white"><%= currentUser.username %></span>.
          <% if (currentUser.role === "admin") { %>
            You can review, edit, and remove user accounts from the admin panel.
          <% } else { %>
            Your account is active and securely stored in the file-based backend.
          <% } %>
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <% if (currentUser.role === "admin") { %>
            <a
              href="/admin/users"
              class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-100"
            >
              Open user management
            </a>
          <% } %>
          <form action="/logout" method="post">
            <button
              type="submit"
              class="rounded-full border border-white/10 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/40 hover:text-white"
            >
              Logout
            </button>
          </form>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-slate-950/50 p-8 shadow-panel">
        <h2 class="text-lg font-semibold text-white">Profile details</h2>
        <dl class="mt-6 space-y-4 text-sm text-slate-300">
          <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
            <dt class="text-slate-400">Full name</dt>
            <dd class="font-medium text-white"><%= currentUser.name %></dd>
          </div>
          <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
            <dt class="text-slate-400">Username</dt>
            <dd class="font-medium text-white"><%= currentUser.username %></dd>
          </div>
          <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
            <dt class="text-slate-400">Email</dt>
            <dd class="font-medium text-white"><%= currentUser.email %></dd>
          </div>
          <div class="flex items-center justify-between gap-4">
            <dt class="text-slate-400">Role</dt>
            <dd class="rounded-full bg-cyan-300/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">
              <%= currentUser.role %>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <% if (stats) { %>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-3xl border border-white/10 bg-white/10 p-6 shadow-panel backdrop-blur">
          <p class="text-sm text-slate-400">Total accounts</p>
          <p class="mt-3 text-3xl font-bold text-white"><%= stats.totalUsers %></p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/10 p-6 shadow-panel backdrop-blur">
          <p class="text-sm text-slate-400">Standard users</p>
          <p class="mt-3 text-3xl font-bold text-white"><%= stats.standardUsers %></p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/10 p-6 shadow-panel backdrop-blur">
          <p class="text-sm text-slate-400">Admin access</p>
          <p class="mt-3 text-3xl font-bold text-white">1</p>
        </div>
      </div>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
